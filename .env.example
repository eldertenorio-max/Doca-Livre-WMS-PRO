# ==============================================================
# Configuração para deploy (Supabase + Render)
# ==============================================================
# Copie este arquivo para .env e preencha os valores
# ==============================================================

# Banco de dados (Supabase Postgres — projeto Doca Livre WMS PRO: wbqyufalamdsgurejvyz)
# Deixe vazio para usar SQLite local
# Render: use Transaction pooler (porta 6543). Migração: Session URI (porta 5432).
DATABASE_URL=postgresql://postgres.wbqyufalamdsgurejvyz:[password]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

# Copie para .env e preencha (nao commitar):
# SUPABASE_DB_PASSWORD=sua_senha_do_banco

# SSL do Postgres (Supabase normalmente exige 'require')
PGSSLMODE=require

# Chave secreta do Flask (sessão/login)
# IMPORTANTE: Use uma chave forte em produção
SECRET_KEY=sua-chave-secreta-aqui-mude-isso

# SSO portal único — link público no domínio do Plus (sem onrender no meio)
# Produção:    https://wms.docalivre.com.br/
# Homologação: https://ultrafrio-homologacao.onrender.com/
#
# Use o MESMO SSO_SECRET nos 2 serviços do Pro e no secret da Edge Function sso-entrar (Light).
SSO_SECRET=troque-por-uma-chave-longa-aleatoria
PORTAL_PUBLIC_URL=https://wms.docalivre.com.br/
SYSTEM_URL_LIGHT=https://doca-livre-wms-light.onrender.com/
SYSTEM_URL_PLUS=https://wms.docalivre.com.br/
SYSTEM_URL_PRO=https://doca-livre-wms-pro.onrender.com/
# Homologação (serviço doca-livre-wms-pro-homologacao):
# PORTAL_PUBLIC_URL=https://ultrafrio-homologacao.onrender.com/
# SYSTEM_URL_LIGHT=https://doca-livre-wms-light-homolog.onrender.com/
# SYSTEM_URL_PLUS=https://ultrafrio-homologacao.onrender.com/
# SYSTEM_URL_PRO=https://doca-livre-wms-pro-homologacao.onrender.com/

# Ambiente: producao (padrão) ou homologacao (Render define automaticamente no serviço homolog)
# APP_ENV=homologacao

# Porta (Render define automaticamente, mas pode forçar local)
# PORT=5001

# Meu Danfe — DANFE em PDF a partir do XML da NF (aba Terceiros → Ver PDF da NF)
# Crie a Api-Key em https://meudanfe.com.br (menu API / Integração)
MEU_DANFE_API_KEY=
# MEU_DANFE_API_URL=https://api.meudanfe.com.br/v2/fd/convert/xml-to-da
# MEU_DANFE_TIMEOUT=60

# E-mail Gmail — avisos + portal (cadastro / trocar senha)
# No Render o SMTP do Gmail costuma falhar (Network unreachable). Preferir Resend (HTTPS):
#   RESEND_API_KEY=re_xxxx
#   RESEND_FROM=Doca Livre <onboarding@resend.dev>   # teste; depois use domínio verificado
# Alternativa SMTP (pode falhar no plano free do Render):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=docalivrewms@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM=docalivrewms@gmail.com
# SMTP_USE_TLS=1
# PORTAL_OTP_DEBUG=0
# TERCEIROS_CONSUMIVEL_SP_EMAILS=elder.tenorio@ultrapao.com.br,jackeline.silva@ultrapao.com.br,suellen.oliveira@ultrapao.com.br,mariana.teixeira@ultrapao.com.br,astro.santos@ultrapao.com.br
#
# Diagnóstico (logado): GET /api/terceiros/email/diagnostico
# Teste de envio (logado): POST /api/terceiros/email/teste
