# ==============================================================
# Configuração para deploy (Supabase + Render)
# ==============================================================
# Copie este arquivo para .env e preencha os valores
# ==============================================================

# Banco de dados (Supabase Postgres)
# Deixe vazio para usar SQLite local
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# SSL do Postgres (Supabase normalmente exige 'require')
PGSSLMODE=require

# Chave secreta do Flask (sessão/login)
# IMPORTANTE: Use uma chave forte em produção
SECRET_KEY=sua-chave-secreta-aqui-mude-isso

# Porta (Render define automaticamente, mas pode forçar local)
# PORT=5001

# Meu Danfe — DANFE em PDF a partir do XML da NF (aba Terceiros → Ver PDF da NF)
# Crie a Api-Key em https://meudanfe.com.br (menu API / Integração)
MEU_DANFE_API_KEY=
# MEU_DANFE_API_URL=https://api.meudanfe.com.br/v2/fd/convert/xml-to-da
# MEU_DANFE_TIMEOUT=60

# E-mail Gmail — aviso quando consumível SP vai para lançamento (recebimento concluído)
# 1) Conta Google com verificação em 2 etapas ativa
# 2) Criar "Senha de app" em https://myaccount.google.com/apppasswords
# 3) Usar essa senha de 16 caracteres em SMTP_PASSWORD (NÃO a senha normal do Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seuemail@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM=seuemail@gmail.com
# SMTP_USE_TLS=1
# TERCEIROS_CONSUMIVEL_SP_EMAILS=elder.tenorio@ultrapao.com.br,jackeline.silva@ultrapao.com.br,suellen.oliveira@ultrapao.com.br,mariana.teixeira@ultrapao.com.br,astro.santos@ultrapao.com.br
